{
  "expo": {
    "name": "audio-assist",
    "slug": "audio-assist",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "audioassist",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Listens for sounds."
      },
      "bundleIdentifier": "com.daddia.audioassist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.daddia.audioassist"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-asset",
      "./plugins/withMicPermissions.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
